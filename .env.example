# Frontend Environment Variables

# Backend API URL
VITE_API_URL=http://localhost:3001/api

# Yandex Maps API Key
# Get your key at https://developer.tech.yandex.ru/
# Select "JavaScript API и HTTP Геокодер"
VITE_YANDEX_MAPS_API_KEY=YOUR_API_KEY_HERE

# Yandex Maps API Key (optional, for future integration)
VITE_YANDEX_MAPS_KEY=your_yandex_maps_api_key_here
