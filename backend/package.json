{
  "name": "truedom-backend",
  "version": "1.0.0",
  "description": "TrueDom Real Estate Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "psql -U postgres -d truedom -f database/schema.sql",
    "db:seed": "ts-node database/seeds/seed.ts",
    "db:reset": "psql -U postgres -d truedom -f database/schema.sql && npm run db:seed",
    "lint": "tsc --noEmit"
  },
  "keywords": ["real-estate", "proptech", "api"],
  "author": "TrueDom Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
